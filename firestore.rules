rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isStaff() {
      return isSignedIn() && request.auth.token.role in ['admin', 'supervisor', 'vendor', 'cashier'];
    }

    // OTP storage: ONLY backend (Cloud Functions, admin SDK) may read/write.
    match /otp_codes/{phone} {
      allow read, write: if false;
    }

    // Public-readable program images & promotions; staff manages.
    match /program_images/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promotions/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Race programs, results, prices: public read, admin/supervisor write.
    match /races/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /race_results/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /all_bets_prices/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Users / vendors / customers: signed-in read of own doc, admin full.
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow create: if isAdmin();
      allow update, delete: if isAdmin() || request.auth.uid == userId;
    }

    // Tickets: customer can read own; staff full.
    match /tickets/{id} {
      allow read: if isSignedIn() && (resource.data.customer_id == request.auth.uid || isStaff());
      allow create: if isSignedIn();
      allow update, delete: if isStaff();
    }

    // Wallet deposits / withdrawals: staff manages, customer reads own.
    match /deposit_logs/{id} {
      allow read: if isSignedIn() && (resource.data.customer_id == request.auth.uid || isStaff());
      allow write: if isStaff();
    }

    match /withdrawal_requests/{id} {
      allow read: if isSignedIn() && (resource.data.customer_id == request.auth.uid || isStaff());
      allow write: if isStaff();
    }

    match /manual_bet_orders/{id} {
      allow read, write: if isStaff();
    }

    // Chat threads & messages: participants only.
    match /chat_threads/{threadId} {
      allow read, write: if isSignedIn() &&
        (request.auth.uid in resource.data.participants || isStaff());
    }

    match /chat_messages/{id} {
      allow read, write: if isSignedIn() &&
        (resource.data.sender_id == request.auth.uid || isStaff());
    }

    // Payment integration config: admin only.
    match /payment_configs/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /otp_config/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ModemPay event log (written by webhook only).
    match /modempay_events/{id} {
      allow read: if isStaff();
      allow write: if false;
    }

    // Fallback — closed by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
