{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "app/**/*",
    "lib/**/*",
    "components/**/*",
    "App.tsx",
    "LanguageContext.tsx",
    "constants.ts",
    "monitor.ts",
    "perf.ts",
    "firebaseClient.ts",
    "types.ts",
    "utils.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "android",
    "dist",
    "netlify",
    "supabase",
    "scripts",
    "index.tsx",
    "vite.config.ts",
    "capacitor.config.ts"
  ]
}
