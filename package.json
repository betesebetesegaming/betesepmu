{
  "name": "betese-pmu-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/betesebetesegaming/betesepmu.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open": "npx cap open android",
    "sunmi:bench:full": "powershell -ExecutionPolicy Bypass -File scripts/sunmi-benchmark.ps1 -PackageName com.betese.pmu -Runs 5",
    "sunmi:bench:lite": "powershell -ExecutionPolicy Bypass -File scripts/sunmi-benchmark.ps1 -PackageName com.betese.pmu.poslite -Runs 5",
    "sunmi:bench:proxy": "powershell -ExecutionPolicy Bypass -File scripts/sunmi-proxy-benchmark.ps1",
    "sunmi:bench:macro": "powershell -ExecutionPolicy Bypass -File scripts/sunmi-macrobenchmark.ps1 -Target full"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@supabase/supabase-js": "^2.87.1",
    "@tailwindcss/vite": "^4.2.2",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "supabase": "^2.93.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
