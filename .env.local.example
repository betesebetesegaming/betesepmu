# ============================================================================
# Firebase Admin SDK (server-only — NEVER commit, never expose)
# Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
# Then copy these three values from the downloaded JSON.
# IMPORTANT: FIREBASE_PRIVATE_KEY contains literal \n sequences — keep them as-is.
# ============================================================================
FIREBASE_PROJECT_ID=betesepmu-32905
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ============================================================================
# AfriMoney (server-only — UAT/sandbox values from the integration spec)
# UAT host: https://api.sandbox.afrimoney.gm  (MERCHPAY / CashIn / getUser / TransactionEnquiry)
# Switch AFRIMONEY_BASE_URL to https://api.afrimoney.gm for production once Africell
# certifies the integration.
# ============================================================================
AFRIMONEY_BASE_URL=https://api.sandbox.afrimoney.gm
AFRIMONEY_MERCHANT_MSISDN=7700032323
AFRIMONEY_MERCHANT_PRODUCT_ID=12
AFRIMONEY_MPIN=1357
AFRIMONEY_TPIN=1357
# Paste the Bearer access token Africell issued for the UAT channel user below.
# The spec does not publish a sample token — without it /MERCHPAY returns 401.
AFRIMONEY_ACCESS_TOKEN=

# ============================================================================
# Africell SMS Gateway (server-only — OTP delivery)
# Used by /api/send-otp. Basic-auth POST to {URL}/api/sendsms.
# ============================================================================
AFRICELL_SMS_URL=https://esme.africell.gm:5991
AFRICELL_SMS_USERNAME=
AFRICELL_SMS_PASSWORD=
AFRICELL_SMS_SENDER=Betese
# Salt used when hashing OTP codes in Firestore. Change to any random string.
OTP_HASH_SALT=

